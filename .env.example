# ======================================
# Настройки базы данных (Turso / LibSQL)
# ======================================
# Если переменные ниже НЕ заданы — используется локальная SQLite (sql.js, файл flower_shop.db).
# Для продакшена рекомендуется Turso (бесплатный облачный SQLite).

# 1. Зарегистрируйтесь на https://turso.tech (бесплатно)
# 2. Установите CLI: npm i -g @turso/cli && turso auth login
# 3. Создайте БД:     turso db create flower-shop
# 4. Получите URL:     turso db show flower-shop --url   → вставить в TURSO_DATABASE_URL
# 5. Получите токен:   turso db tokens create flower-shop → вставить в TURSO_AUTH_TOKEN

TURSO_DATABASE_URL=libsql://your-database-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
